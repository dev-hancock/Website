<div class="timeline-item">
    <div class="timeline-dot">
    </div>
    <div class="timeline-content @(Position == TimelinePosition.Left ? "left" : "right")">
        <div>
            <h5>@Date</h5>
            <h3>@Company</h3>
            <h4>@Title</h4>
        </div>
        @if (ChildContent != null)
        {
            <div class="timeline-details @(IsExpanded ? "expanded" : "collapsed")">
                @ChildContent
            </div>
            <a class="read-more" @onclick="@(() => Toggle(!IsExpanded))">
                @if (IsExpanded)
                {
                    <span>Read Less</span>
                }
                else
                {
                    <span>Read More</span>
                }
            </a>
        }
    </div>
</div>
